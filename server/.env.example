NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173
API_PREFIX=/api/v1
MONGODB_URI=mongodb://localhost:27017/wacrm
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=7d
AUTH_COOKIE_NAME=wacrm_token
AUTH_COOKIE_MAX_AGE_MS=604800000
RAZORPAY_KEY_ID=replace-with-your-razorpay-key-id
RAZORPAY_KEY_SECRET=replace-with-your-razorpay-key-secret
RAZORPAY_API_BASE_URL=https://api.razorpay.com/v1
